# Copy this file to .env and fill in the values you need.
# The app runs fully offline with zero configuration (LLM_PROVIDER=mock).

# Which LLM backend to use: "mock" (default, offline/deterministic),
# "anthropic", "openai", or "hermes".
LLM_PROVIDER=mock

# Required only when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Required only when LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Required only when LLM_PROVIDER=hermes. Hermes (NousResearch) models are
# served over an OpenAI-compatible chat-completions endpoint - point this at
# whichever one you run (Ollama, vLLM, LM Studio, OpenRouter, ...), e.g.
# http://localhost:11434/v1 for Ollama.
HERMES_BASE_URL=
HERMES_MODEL=
# Optional - many local servers (e.g. Ollama) don't check the API key at
# all; the client falls back to a placeholder if left unset.
HERMES_API_KEY=

# Number of user/assistant turn-pairs kept verbatim before older history is
# summarized and compacted out of the active context window.
MAX_TURNS_BEFORE_SUMMARY=8

# SQLite database file path (created automatically at runtime).
DATABASE_PATH=assistant.db

# Backend host/port, used by the Streamlit UI to reach the FastAPI backend.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_URL=http://127.0.0.1:8000
